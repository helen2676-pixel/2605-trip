//  HELPERS
// ═══════════════════════════════════════════
function findDay(dayId) { return itinerary.days.find(d => d.id === dayId); }
function findCard(dayId, sectionId, cardId) {
  const day = findDay(dayId);
  if (!day) return null;
  const sec = day.sections[sectionId];
  if (!sec) return null;
  return sec.find(c => c.id === cardId);
}
function mapsUrl(q) {
  if (!q) return null;
  return `https://www.google.com/maps/search/${encodeURIComponent(q)}`;
}
function showToast(msg) {
  const t = document.getElementById("toast");
  t.textContent = msg; t.classList.add("show");
  setTimeout(() => t.classList.remove("show"), 2200);
}
function checkPendingRender() {
  if (window.pendingRender) {
    window.pendingRender = false;
    render();
    showToast("🔄 대기 중인 일정 변경사항 반영됨");
  }
}

