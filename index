<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>규슈 가족여행 플래너</title>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700&display=swap"/>
<style>
/* 기존 스타일 그대로 유지 (생략) */
</style>
</head>
<body>

<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore-compat.js"></script>
<script>
// ═══════════════════════════════════════════
//  수정된 Firebase 핵심 로직
// ═══════════════════════════════════════════

async function initFb(cfg) {
  try {
    if (typeof firebase === 'undefined') return false;
    
    // 1. 기존 앱 인스턴스 정리 (중복 초기화 방지)
    if (firebase.apps.length > 0) {
      for (const app of firebase.apps) {
        await app.delete();
      }
    }
    
    // 2. 초기화
    firebase.initializeApp(cfg);
    db = firebase.firestore();
    const ref = db.collection("kyushu2026").doc("shared");

    // 3. 리스너 중복 방지
    if (fbUnsub) fbUnsub();

    fbUnsub = ref.onSnapshot(snap => {
      if (!snap.exists) return;
      const data = snap.data();
      if (data && data.updatedBy !== CLIENT_ID) {
        itinerary = data.itinerary;
        localStorage.setItem(STORAGE_KEY, JSON.stringify(itinerary));
        render();
        showToast("🔄 공유 일정 업데이트됨");
      }
    });

    fbReady = true;
    console.log("Firebase Connected");
    return true;
  } catch(e) {
    console.error("Firebase Init Error:", e);
    return false;
  }
}
// 나머지 스크립트 (render, drag&drop 등) ...
</script>
</body>
</html>
