function openNearby(cat) {
  const cfg = NEARBY_CONFIG[cat];
  const kw = cfg.keyword;
  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(
      pos => window.open(`https://www.google.com/maps/search/${encodeURIComponent(kw)}/@${pos.coords.latitude},${pos.coords.longitude},15z`, "_blank"),
      ()   => window.open(`https://www.google.com/maps/search/${encodeURIComponent(kw + " 九州")}`, "_blank"),
      { timeout: 5000 }
    );
  } else {
    window.open(`https://www.google.com/maps/search/${encodeURIComponent(kw + " 九州")}`, "_blank");
  }
}

