//  RENDER
// ═══════════════════════════════════════════
function render() {
  renderDayNav();
  renderDays();
}

function renderDayNav() {
  const nav = document.getElementById("day-nav");
  nav.innerHTML = itinerary.days.map(d => {
    const w = weatherData[d.date ? dateKeyFromLabel(d.date) : null];
    const wi = w ? w.icon : "";
    return `<button class="day-btn" onclick="scrollToDay('${d.id}')">${d.label} ${wi} ${d.date || ""}</button>`;
  }).join("");
}

function dateKeyFromLabel(label) {
  const m = label.match(/(\d+)월\s*(\d+)일/);
  if (!m) return null;
  return `2026-${String(m[1]).padStart(2,"0")}-${String(m[2]).padStart(2,"0")}`;
}

function renderDays() {
  const main = document.getElementById("main-content");
  main.innerHTML = itinerary.days.map(day => renderDay(day)).join("");
}

function renderDay(day) {
  const dateKey = dateKeyFromLabel(day.date);
  const w = weatherData[dateKey];
  const rainBadge = w && w.rainy ? `<span class="day-header-weather">⛈ 우천주의</span>` : (w ? `<span class="day-header-weather">${w.icon} ${w.max}°/${w.min}°</span>` : "");

  const sectionsHtml = MEAL_SECTIONS.map(ms => {
    const cards = (day.sections[ms.id] || []);
    const cardsHtml = cards.map(c => renderCard(day.id, ms.id, c)).join("");
    return `<div class="meal-section" id="ms-${day.id}-${ms.id}">
      <div class="meal-header">
        <span class="meal-icon">${ms.icon}</span>
        <span class="meal-label">${ms.label}</span>
        <button class="meal-add-inline" onclick="openAddModal('${day.id}','${ms.id}')">＋ 추가</button>
      </div>
      <div class="meal-cards" id="mc-${day.id}-${ms.id}"
        ondragover="onDragOver(event,'${day.id}','${ms.id}')"
        ondrop="onDrop(event,'${day.id}','${ms.id}')"
        ondragleave="onDragLeave(event)">
        ${cardsHtml}
      </div>
    </div>`;
  }).join("");

  return `<div class="day-section" id="${day.id}">
    <div class="day-header" style="background:${day.color}">
      <div class="day-header-left">
        <div class="day-header-title">${day.label} · ${day.theme}</div>
        <div class="day-header-sub">${day.date}</div>
      </div>
      ${rainBadge}
    </div>
