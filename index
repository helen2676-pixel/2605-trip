// ═══════════════════════════════════════════
//  FIREBASE (업그레이드: 에러 캐치 & 충돌 방지)
// ═══════════════════════════════════════════
function loadFbCfg() { try { return JSON.parse(localStorage.getItem(FB_CONFIG_KEY)); } catch { return null; } }

async function initFb(cfg) {
  try {
    if (typeof firebase === 'undefined') { console.warn("Firebase SDK 미로드"); return false; }
    
    // 앱 초기화 로직 (충돌 방지)
    if (firebase.apps.length === 0) {
      firebase.initializeApp(cfg);
    } else if (firebase.app().options.projectId !== cfg.projectId) {
      await firebase.app().delete();
      firebase.initializeApp(cfg);
    }
    
    db = firebase.firestore();
    const ref = db.collection("kyushu2026").doc("shared");

    if (fbUnsub) fbUnsub();

    fbUnsub = ref.onSnapshot(snap => {
      if (!snap.exists) return;

      const data = snap.data();
      if (!data || !data.itinerary) return;

      const remote = JSON.stringify(data.itinerary);
      const local = JSON.stringify(itinerary);

      if (data.updatedBy === CLIENT_ID) return;

      if (remote !== local) {
        itinerary = data.itinerary;
        localStorage.setItem(STORAGE_KEY, JSON.stringify(itinerary));
        
        // 사용자가 드래그 중일 때는 렌더링을 멈췄다가, 마우스를 뗄 때 반영합니다. (버그 방지)
        if (document.body.classList.contains("dragging-active")) {
          showToast("🔄 업데이트 대기 중 (드래그 종료 후 반영)");
          window.pendingRender = true;
        } else {
          render();
          showToast("🔄 공유 일정 업데이트됨");
        }
      }
    }, err => {
      console.error("Firestore sync error:", err);
    });

    const firstSnap = await ref.get();
    if (firstSnap.exists) {
      const serverData = firstSnap.data();
      if (serverData && serverData.itinerary) {
        itinerary = serverData.itinerary;
        localStorage.setItem(STORAGE_KEY, JSON.stringify(itinerary));
      }
    } else {
      await ref.set({
        itinerary,
        updatedAt: firebase.firestore.FieldValue.serverTimestamp(),
        updatedBy: CLIENT_ID
      });
    }

    fbReady = true;
    document.getElementById("fb-banner").classList.add("ok");
    document.getElementById("fb-status").textContent = "✅ 연결됨";
    document.getElementById("sync-dot").classList.add("on");
    document.getElementById("sync-label").textContent = "온라인";
    window.lastFbError = null;

    render();
    return true;
  } catch(e) {
    console.error("Firebase Init Error:", e);
    window.lastFbError = e.message; // 알림창 출력을 위해 저장
    return false;
  }
}

window.saveFirebaseConfig = async function() {
  const cfg = {
    apiKey: document.getElementById("fb-apikey").value.trim(),
    authDomain: document.getElementById("fb-authdomain").value.trim(),
    projectId: document.getElementById("fb-projectid").value.trim(),
    appId: document.getElementById("fb-appid").value.trim(),
  };
  if (!cfg.apiKey || !cfg.projectId) { alert("API Key와 Project ID는 필수입니다."); return; }
  localStorage.setItem(FB_CONFIG_KEY, JSON.stringify(cfg));
  const ok = await initFb(cfg);
  
  if (ok) { 
    document.getElementById("setup-modal").classList.remove("open"); 
    showToast("🔥 Firebase 연결 완료!"); 
  } else {
    // 상세 에러 안내
    alert("연결 실패. 설정값을 확인해 주세요.\n\n(상세: " + (window.lastFbError || "원인 불명") + ")\n\n※ 만약 'Missing or insufficient permissions' 라면 Firestore 보안 규칙을 확인해주세요!");
  }
};

// ═══════════════════════════════════════════
//  WEATHER (Open-Meteo, 무료 API)
// ═══════════════════════════════════════════
async function loadWeather() {
  const lat = 33.284, lon = 131.491;
  try {
    const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&daily=weathercode,temperature_2m_max,temperature_2m_min,precipitation_sum&hourly=weathercode,temperature_2m,precipitation_probability&timezone=Asia%2FTokyo&forecast_days=7&past_days=7`;
    const res = await fetch(url);
    const d = await res.json();

    const WC = {
      0:"☀️",1:"🌤",2:"⛅",3:"☁️",
      45:"🌫",48:"🌫",51:"🌦",53:"🌦",55:"🌧",
      61:"🌧",63:"🌧",65:"🌧",71:"🌨",73:"🌨",80:"🌦",81:"🌧",82:"⛈",
      95:"⛈",96:"⛈",99:"⛈"
    };
    const getIcon = c => WC[c] || "🌡";
    const isRainy = c => [51,53,55,61,63,65,80,81,82,95,96,99].includes(c);

    const tripDates = ["2026-05-23","2026-05-24","2026-05-25","2026-05-26","2026-05-27"];
    const dayLabels = ["Day1","Day2","Day3","Day4","Day5"];

    weatherData = {};
    tripDates.forEach((date, i) => {
      const idx = d.daily.time.indexOf(date);
      if (idx === -1) return;
      const code = d.daily.weathercode[idx];
      const rain = d.daily.precipitation_sum[idx];
      weatherData[date] = {
        icon: getIcon(code), rainy: isRainy(code),
        max: Math.round(d.daily.temperature_2m_max[idx]),
        min: Math.round(d.daily.temperature_2m_min[idx]),
        rain: rain ? `💧${rain}mm` : "",
        label: dayLabels[i],
        hourly: d.hourly.time.filter(t => t.startsWith(date)).map((t,j) => {
          const hi = d.hourly.time.indexOf(t);
          return {
            time: t.slice(11,16),
            icon: getIcon(d.hourly.weathercode[hi]),
            temp: Math.round(d.hourly.temperature_2m[hi]),
            prob: d.hourly.precipitation_probability[hi],
          };
        })
      };
    });

    const todayStr = new Date().toISOString().slice(0,10);
    const pastMessages = ["✨완료","🎉추억","🌟끝","💫다녀옴","🗓기록"];
    const bar = document.getElementById("weather-bar");
    const dateShorts = ["5/23","5/24","5/25","5/26","5/27"];
    bar.innerHTML = tripDates.map((date, i) => {
      const isPast = date < todayStr;
      const w = weatherData[date];
      if (!w) {
        if (isPast) return `<div class="weather-day past" id="wday-${date}"><div class="wd-date">${dayLabels[i]}</div><div class="wd-date">${dateShorts[i]}</div><div class="wd-icon" style="font-size:0.8rem">${pastMessages[i]}</div></div>`;
        return `<div class="weather-day" id="wday-${date}"><div class="wd-date">${dayLabels[i]}</div><div class="wd-date">${dateShorts[i]}</div><div class="wd-icon">🌡</div></div>`;
      }
      if (isPast) {
        return `<div class="weather-day past" id="wday-${date}">
          <div class="wd-date">${dayLabels[i]}</div>
          <div class="wd-date">${dateShorts[i]}</div>
          <div class="wd-icon" style="font-size:0.75rem">${pastMessages[i]}</div>
          <div class="wd-rain" style="font-size:0.58rem;opacity:0.7">${w.icon} ${w.max}°/${w.min}°</div>
        </div>`;
      }
      const rainAlert = w.rainy ? `<div class="wd-rain" style="color:#fde68a">⚠️ 우천</div>` : `<div class="wd-rain">${w.rain || "맑음"}</div>`;
      return `<div class="weather-day" onclick="toggleWeatherDetail('${date}')" id="wday-${date}">
        <div class="wd-date">${dayLabels[i]}</div>
        <div class="wd-date" style="font-size:0.6rem">${dateShorts[i]}</div>
        <div class="wd-icon">${w.icon}</div>
        <div class="wd-temp">${w.min}°~${w.max}°</div>
        ${rainAlert}
      </div>`;
    }).join("");

    render();
  } catch(e) {
    document.getElementById("weather-bar").innerHTML = `<span class="weather-loading">날씨 정보를 불러오지 못했습니다.</span>`;
  }
}

function toggleWeatherDetail(date) {
  const det = document.getElementById("weather-detail");
  const btn = document.getElementById("wday-" + date);
  document.querySelectorAll(".weather-day").forEach(el => el.classList.remove("active"));
  if (activeWeatherDay === date) {
    det.classList.remove("open");
    det.innerHTML = "";
    activeWeatherDay = null;
    return;
  }
  activeWeatherDay = date;
  btn.classList.add("active");
  const w = weatherData[date];
  if (!w) return;
  const hours = w.hourly.filter((_,i) => i % 2 === 0);
  det.innerHTML = hours.map(h => `
    <div class="wh-item">
      <div class="wh-time">${h.time}</div>
      <div class="wh-ic">${h.icon}</div>
      <div>${h.temp}°</div>
      <div>${h.prob}%</div>
    </div>`).join("");
  det.classList.add("open");
}

